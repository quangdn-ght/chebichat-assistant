# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
# Public base URL of this deployment (used for redirects / CORS)
BASE_URL=https://assistant.example.com
# Login page URL (redirect target when unauthenticated)
AUTHEN_PAGE=https://example.com/auth/login
# Optional: URL returned in /api/config for frontend login redirect
AUTH_LOGIN_URL=

# ─────────────────────────────────────────────
# Access control
# ─────────────────────────────────────────────
# Comma-separated access codes; leave empty to disable
CODE=your-access-code
# Hide user-provided API key fields in UI (1 = hide)
HIDE_USER_API_KEY=
# Disable GPT-4 models in UI (1 = disable)
DISABLE_GPT4=
# Disable fast-link feature (1 = disable)
DISABLE_FAST_LINK=
# Comma-separated custom model list shown in UI
CUSTOM_MODELS=
# Default model selected on first load
DEFAULT_MODEL=
# Additional vision-capable model IDs (comma-separated)
VISION_MODELS=
# Enable balance query feature (1 = enable)
ENABLE_BALANCE_QUERY=

# ─────────────────────────────────────────────
# Proxy
# ─────────────────────────────────────────────
# Outbound HTTP/SOCKS proxy, e.g. http://127.0.0.1:7890
PROXY_URL=

# ─────────────────────────────────────────────
# MCP (Model Context Protocol)
# ─────────────────────────────────────────────
ENABLE_MCP=

# ─────────────────────────────────────────────
# OpenAI
# ─────────────────────────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BASE_URL=
OPENAI_ORG_ID=

# ─────────────────────────────────────────────
# Google Gemini
# ─────────────────────────────────────────────
GOOGLE_API_KEY=
GOOGLE_URL=

# ─────────────────────────────────────────────
# Anthropic Claude
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_API_VERSION=2023-06-01
ANTHROPIC_URL=

# ─────────────────────────────────────────────
# Azure OpenAI
# ─────────────────────────────────────────────
AZURE_URL=
AZURE_API_KEY=
AZURE_API_VERSION=

# ─────────────────────────────────────────────
# Alibaba DashScope
# ─────────────────────────────────────────────
ALIBABA_API_KEY=
ALIBABA_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/
ALIBABA_APP_ID=

# ─────────────────────────────────────────────
# DeepSeek
# ─────────────────────────────────────────────
DEEPSEEK_API_KEY=
DEEPSEEK_URL=

# ─────────────────────────────────────────────
# Baidu Ernie
# ─────────────────────────────────────────────
BAIDU_API_KEY=
BAIDU_SECRET_KEY=
BAIDU_URL=

# ─────────────────────────────────────────────
# ByteDance (Doubao)
# ─────────────────────────────────────────────
BYTEDANCE_API_KEY=
BYTEDANCE_URL=

# ─────────────────────────────────────────────
# Moonshot
# ─────────────────────────────────────────────
MOONSHOT_API_KEY=
MOONSHOT_URL=

# ─────────────────────────────────────────────
# iFlytek Spark
# ─────────────────────────────────────────────
IFLYTEK_API_KEY=
IFLYTEK_API_SECRET=
IFLYTEK_URL=

# ─────────────────────────────────────────────
# Tencent Hunyuan
# ─────────────────────────────────────────────
TENCENT_SECRET_KEY=
TENCENT_SECRET_ID=
TENCENT_URL=

# ─────────────────────────────────────────────
# xAI (Grok)
# ─────────────────────────────────────────────
XAI_API_KEY=
XAI_URL=

# ─────────────────────────────────────────────
# ChatGLM
# ─────────────────────────────────────────────
CHATGLM_API_KEY=
CHATGLM_URL=

# ─────────────────────────────────────────────
# SiliconFlow
# ─────────────────────────────────────────────
SILICONFLOW_API_KEY=
SILICONFLOW_URL=

# ─────────────────────────────────────────────
# Stability AI
# ─────────────────────────────────────────────
STABILITY_API_KEY=
STABILITY_URL=

# ─────────────────────────────────────────────
# Supabase (user auth / storage)
# ─────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# ─────────────────────────────────────────────
# Upstash Redis (chat sync)
# ─────────────────────────────────────────────
KV_REST_API_URL=https://your-instance.upstash.io
KV_REST_API_TOKEN=your-upstash-rest-token
KV_REST_API_READ_ONLY_TOKEN=
KV_URL=
REDIS_URL=

# ─────────────────────────────────────────────
# Cloudflare KV (chat sync – alternative)
# ─────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_KV_NAMESPACE_ID=
CLOUDFLARE_KV_API_KEY=
CLOUDFLARE_KV_TTL=

# ─────────────────────────────────────────────
# WebDAV
# ─────────────────────────────────────────────
WHITE_WEBDAV_ENDPOINTS=

# ─────────────────────────────────────────────
# Analytics
# ─────────────────────────────────────────────
GTM_ID=
GA_ID=
